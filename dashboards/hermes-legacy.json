{
  "title": "Hermes 9Router",
  "uid": "hermes-9router",
  "description": "Complete observability for Hermes 9Router — spending, health, quotas, scores, alerts, and model usage",
  "tags": ["hermes", "9router", "llm", "routing"],
  "schemaVersion": 36,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "label": "Prometheus"
      }
    ]
  },
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "collapsed": false,
      "title": "Spending & Budget",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "usd",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "orange", "value": 37.5 },
              { "color": "red", "value": 45 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 100,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_cost_total",
          "legendFormat": "Spent",
          "refId": "A"
        },
        {
          "expr": "hermes_cost_monthly_budget",
          "legendFormat": "Budget",
          "refId": "B"
        },
        {
          "expr": "hermes_cost_budget_remaining",
          "legendFormat": "Remaining",
          "refId": "C"
        }
      ],
      "title": "Monthly Budget",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "usd",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 101,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "hermes_cost_daily_spend",
          "legendFormat": "Daily spend",
          "refId": "A"
        },
        {
          "expr": "hermes_cost_projected_monthly",
          "legendFormat": "Projected monthly",
          "refId": "B"
        }
      ],
      "title": "Daily & Projected Spend",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 102,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_cost_budget_percent",
          "legendFormat": "Budget used",
          "refId": "A"
        }
      ],
      "title": "Budget Usage",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 103,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_budget_zone",
          "legendFormat": "Zone (0=G,1=Y,2=O,3=R)",
          "refId": "A"
        }
      ],
      "title": "Budget Zone",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "collapsed": false,
      "title": "Provider Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 200,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_health_score",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "Provider Health Scores",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 201,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "expr": "hermes_model_score",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Model Smart Scores",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "collapsed": false,
      "title": "Model Usage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "id": 300,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_model_tokens_used",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Tokens Used per Model",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "id": 301,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_model_tokens_limit",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Token Limits per Model",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "id": 302,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_model_usage_percent",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Usage % per Model",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 303,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "hermes_model_tokens_used",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Token Usage Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 304,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "hermes_model_rank",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Fallback Order (Rank)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "collapsed": false,
      "title": "Quotas",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 400,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_quota_percent",
          "legendFormat": "{{provider}} - {{type}}",
          "refId": "A"
        }
      ],
      "title": "Quota Usage % per Provider",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 401,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "expr": "hermes_quota_remaining",
          "legendFormat": "{{provider}} - {{type}}",
          "refId": "A"
        }
      ],
      "title": "Quota Remaining",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "collapsed": false,
      "title": "Alerts",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 43 },
      "id": 500,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_active_alerts{severity=\"warning\"}",
          "legendFormat": "Warnings",
          "refId": "A"
        },
        {
          "expr": "hermes_active_alerts{severity=\"critical\"}",
          "legendFormat": "Criticals",
          "refId": "B"
        }
      ],
      "title": "Active Alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 43 },
      "id": 501,
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "hermes_active_alerts{severity=\"critical\"}",
          "legendFormat": "Critical alerts",
          "refId": "A"
        }
      ],
      "title": "Critical Alerts",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "collapsed": true,
      "title": "Pi-hole DNS (Optional Extra)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 50 },
      "id": 600,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(pihole_total_queries[5m])",
          "legendFormat": "Total queries/s",
          "refId": "A"
        },
        {
          "expr": "rate(pihole_blocked_queries[5m])",
          "legendFormat": "Blocked queries/s",
          "refId": "B"
        }
      ],
      "title": "DNS Query Rate (5m avg)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 50 },
      "id": 601,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "increase(pihole_total_queries[15m])",
          "legendFormat": "Total queries/15m",
          "refId": "A"
        },
        {
          "expr": "increase(pihole_blocked_queries[15m])",
          "legendFormat": "Blocked queries/15m",
          "refId": "B"
        }
      ],
      "title": "DNS Queries per 15 min",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 50 },
      "id": 602,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "pihole_queries_last_15m{type=\"total\"}",
          "legendFormat": "Last 15m",
          "refId": "A"
        },
        {
          "expr": "pihole_queries_last_15m{type=\"blocked\"}",
          "legendFormat": "Blocked (15m)",
          "refId": "B"
        }
      ],
      "title": "Pi-hole Queries (Last 15m)",
      "type": "stat"
    }
  ]
}
