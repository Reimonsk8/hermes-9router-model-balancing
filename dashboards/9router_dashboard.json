{
  "annotations": [
    {
      "kind": "AnnotationQuery",
      "spec": {
        "builtIn": true,
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "query": {
          "datasource": {
            "name": "-- Grafana --"
          },
          "group": "grafana",
          "kind": "DataQuery",
          "spec": {},
          "version": "v0"
        }
      }
    }
  ],
  "cursorSync": "Off",
  "editable": true,
  "elements": {},
  "layout": {
    "kind": "GridLayout",
    "spec": {
      "items": [
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "none"
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Total Requests",
            "description": "Total API requests routed through 9Router",
            "gridPos": {
              "h": 4,
              "w": 6,
              "x": 0,
              "y": 0
            },
            "targets": [
              {
                "expr": "9router_total_requests_total",
                "legendFormat": "__auto",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "auto",
              "justifyMode": "auto",
              "textMode": "auto",
              "colorMode": "value",
              "graphMode": "none"
            },
            "type": "stat",
            "pluginId": "stat"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short"
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Total Input Tokens",
            "description": "Total input (prompt) tokens consumed",
            "gridPos": {
              "h": 4,
              "w": 6,
              "x": 6,
              "y": 0
            },
            "targets": [
              {
                "expr": "9router_total_input_tokens_total",
                "legendFormat": "__auto",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "auto",
              "justifyMode": "auto",
              "textMode": "auto",
              "colorMode": "value",
              "graphMode": "none"
            },
            "type": "stat",
            "pluginId": "stat"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short"
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Total Output Tokens",
            "description": "Total output (completion) tokens generated",
            "gridPos": {
              "h": 4,
              "w": 6,
              "x": 12,
              "y": 0
            },
            "targets": [
              {
                "expr": "9router_total_output_tokens_total",
                "legendFormat": "__auto",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "auto",
              "justifyMode": "auto",
              "textMode": "auto",
              "colorMode": "value",
              "graphMode": "none"
            },
            "type": "stat",
            "pluginId": "stat"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "usd"
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Est. Total Cost",
            "description": "Estimated total cost across all models",
            "gridPos": {
              "h": 4,
              "w": 6,
              "x": 18,
              "y": 0
            },
            "targets": [
              {
                "expr": "9router_total_cost_dollars",
                "legendFormat": "__auto",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "auto",
              "justifyMode": "auto",
              "textMode": "auto",
              "colorMode": "value",
              "graphMode": "none"
            },
            "type": "stat",
            "pluginId": "stat"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "none",
                "min": 0
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Requests per Model",
            "description": "Total API requests by model",
            "gridPos": {
              "h": 8,
              "w": 8,
              "x": 0,
              "y": 4
            },
            "targets": [
              {
                "expr": "9router_model_requests_total",
                "legendFormat": "{{model}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "horizontal",
              "showThresholdLabels": false,
              "showThresholdMarkers": true
            },
            "type": "bargauge",
            "pluginId": "bargauge"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "usd",
                "min": 0
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Cost per Model",
            "description": "Estimated cost by model (from 9Router data)",
            "gridPos": {
              "h": 8,
              "w": 8,
              "x": 8,
              "y": 4
            },
            "targets": [
              {
                "expr": "9router_model_cost_dollars",
                "legendFormat": "{{model}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "horizontal",
              "showThresholdLabels": false,
              "showThresholdMarkers": true
            },
            "type": "bargauge",
            "pluginId": "bargauge"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "min": 0
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Tokens per Model",
            "description": "Combined input+output tokens by model",
            "gridPos": {
              "h": 8,
              "w": 8,
              "x": 16,
              "y": 4
            },
            "targets": [
              {
                "expr": "9router_model_input_tokens_total + 9router_model_output_tokens_total",
                "legendFormat": "{{model}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "horizontal",
              "showThresholdLabels": false,
              "showThresholdMarkers": true
            },
            "type": "bargauge",
            "pluginId": "bargauge"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "reqps"
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Request Rate (15m avg)",
            "description": "Rate of API requests over time (rate is approximated from per-hour counter changes)",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 0,
              "y": 12
            },
            "targets": [
              {
                "expr": "rate(9router_model_requests_total[15m])",
                "legendFormat": "{{model}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "legend": {
                "calcs": [],
                "displayMode": "list",
                "placement": "bottom"
              },
              "tooltip": {
                "mode": "multi",
                "sort": "desc"
              }
            },
            "type": "timeseries",
            "pluginId": "timeseries"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short"
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Input Tokens by Model (over time)",
            "description": "Cumulative input tokens per model",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 12,
              "y": 12
            },
            "targets": [
              {
                "expr": "9router_model_input_tokens_total",
                "legendFormat": "{{model}} (input)",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "legend": {
                "calcs": [],
                "displayMode": "list",
                "placement": "bottom"
              },
              "tooltip": {
                "mode": "multi",
                "sort": "desc"
              }
            },
            "type": "timeseries",
            "pluginId": "timeseries"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "none",
                "custom": {
                  "align": "auto",
                  "cellOptions": {
                    "type": "auto"
                  }
                }
              },
              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "Cost"
                  },
                  "properties": [
                    {
                      "id": "unit",
                      "value": "usd"
                    },
                    {
                      "id": "custom.cellOptions",
                      "value": {
                        "type": "color-text",
                        "mode": "basic"
                      }
                    }
                  ]
                },
                {
                  "matcher": {
                    "id": "byName",
                    "options": "Model"
                  },
                  "properties": [
                    {
                      "id": "custom.width",
                      "value": 300
                    }
                  ]
                }
              ]
            },
            "pluginVersion": "11.5.2",
            "title": "Model Breakdown Table",
            "description": "Complete overview: requests, tokens, and cost per model",
            "gridPos": {
              "h": 10,
              "w": 24,
              "x": 0,
              "y": 20
            },
            "targets": [
              {
                "expr": "9router_model_requests_total",
                "legendFormat": "{{model}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "frameIndex": 0,
              "showHeader": true,
              "footer": {
                "show": true,
                "countRows": false,
                "fields": [
                  {
                    "displayMode": "sum"
                  }
                ],
                "enablePagination": false
              }
            },
            "type": "table",
            "pluginId": "table"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "short",
                "custom": {
                  "insertNulls": false
                }
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "Hourly Request Distribution (last 48h)",
            "description": "API requests grouped by hour from last scrape",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 0,
              "y": 30
            },
            "targets": [
              {
                "expr": "9router_hourly_requests",
                "legendFormat": "{{hour}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "legend": {
                "calcs": [],
                "displayMode": "hidden",
                "placement": "bottom"
              },
              "tooltip": {
                "mode": "single",
                "sort": "none"
              },
              "barAlignment": 0,
              "fullHighlight": false
            },
            "type": "barchart",
            "pluginId": "barchart"
          }
        },
        {
          "kind": "Panel",
          "spec": {
            "datasource": {
              "type": "prometheus",
              "uid": "${datasource}"
            },
            "fieldConfig": {
              "defaults": {
                "unit": "none",
                "min": 0,
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 85
                    }
                  ]
                }
              },
              "overrides": []
            },
            "pluginVersion": "11.5.2",
            "title": "High-Cost Models",
            "description": "Models with estimated cost >= $0.01",
            "gridPos": {
              "h": 8,
              "w": 12,
              "x": 12,
              "y": 30
            },
            "targets": [
              {
                "expr": "9router_model_cost_dollars >= 0.01",
                "legendFormat": "{{model}}",
                "refId": "A",
                "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
                }
              }
            ],
            "options": {
              "orientation": "horizontal",
              "showThresholdLabels": true,
              "showThresholdMarkers": true
            },
            "type": "bargauge",
            "pluginId": "bargauge"
          }
        }
      ]
    }
  },
  "links": [],
  "liveNow": false,
  "preferences": {
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": []
      }
    }
  },
  "preload": false,
  "tags": [
    "9router",
    "llm",
    "usage",
    "cost"
  ],
  "timeSettings": {
    "autoRefresh": "30s",
    "autoRefreshIntervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d"
    ],
    "fiscalYearStartMonth": 0,
    "from": "now-6h",
    "hideTimepicker": false,
    "timezone": "browser",
    "to": "now"
  },
  "title": "9Router Usage Analytics",
  "variables": [
    {
      "name": "datasource",
      "type": "datasource",
      "query": "prometheus",
      "hide": 0,
      "label": "Data Source"
    }
  ]
}
