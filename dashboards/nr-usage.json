{
  "annotations": [
    {
      "kind": "AnnotationQuery",
      "spec": {
        "builtIn": true,
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "query": {
          "datasource": { "name": "-- Grafana --" },
          "group": "grafana",
          "kind": "DataQuery",
          "spec": {},
          "version": "v0"
        }
      }
    }
  ],
  "cursorSync": "Off",
  "editable": true,
  "elements": {
    "requests": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "none" },
          "overrides": []
        },
        "title": "Total Requests",
        "targets": [
          {
            "expr": "nr_requests_total",
            "legendFormat": "__auto",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "auto",
          "justifyMode": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "none"
        },
        "type": "stat",
        "pluginId": "stat",
        "pluginVersion": "11.5.2"
      }
    },
    "input-tokens": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "short" },
          "overrides": []
        },
        "title": "Total Input Tokens",
        "targets": [
          {
            "expr": "nr_input_tokens_total",
            "legendFormat": "__auto",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "auto",
          "justifyMode": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "none"
        },
        "type": "stat",
        "pluginId": "stat",
        "pluginVersion": "11.5.2"
      }
    },
    "output-tokens": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "short" },
          "overrides": []
        },
        "title": "Total Output Tokens",
        "targets": [
          {
            "expr": "nr_output_tokens_total",
            "legendFormat": "__auto",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "auto",
          "justifyMode": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "none"
        },
        "type": "stat",
        "pluginId": "stat",
        "pluginVersion": "11.5.2"
      }
    },
    "cost": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "usd" },
          "overrides": []
        },
        "title": "Est. Total Cost",
        "targets": [
          {
            "expr": "nr_cost_dollars",
            "legendFormat": "__auto",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "auto",
          "justifyMode": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "none"
        },
        "type": "stat",
        "pluginId": "stat",
        "pluginVersion": "11.5.2"
      }
    },
    "requests-per-model": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "none", "min": 0 },
          "overrides": []
        },
        "title": "Requests per Model",
        "targets": [
          {
            "expr": "nr_model_requests_total",
            "legendFormat": "{{model}}",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "horizontal",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "type": "bargauge",
        "pluginId": "bargauge",
        "pluginVersion": "11.5.2"
      }
    },
    "cost-per-model": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "usd", "min": 0 },
          "overrides": []
        },
        "title": "Cost per Model",
        "targets": [
          {
            "expr": "nr_model_cost_dollars",
            "legendFormat": "{{model}}",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "horizontal",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "type": "bargauge",
        "pluginId": "bargauge",
        "pluginVersion": "11.5.2"
      }
    },
    "tokens-per-model": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "short", "min": 0 },
          "overrides": []
        },
        "title": "Tokens per Model",
        "targets": [
          {
            "expr": "nr_model_input_tokens_total + nr_model_output_tokens_total",
            "legendFormat": "{{model}}",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "orientation": "horizontal",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "type": "bargauge",
        "pluginId": "bargauge",
        "pluginVersion": "11.5.2"
      }
    },
    "request-rate": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "reqps" },
          "overrides": []
        },
        "title": "Request Rate (15m avg)",
        "targets": [
          {
            "expr": "rate(nr_model_requests_total[15m])",
            "legendFormat": "{{model}}",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "type": "timeseries",
        "pluginId": "timeseries",
        "pluginVersion": "11.5.2"
      }
    },
    "input-timeseries": {
      "kind": "Panel",
      "spec": {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "fieldConfig": {
          "defaults": { "unit": "short" },
          "overrides": []
        },
        "title": "Input Tokens by Model",
        "targets": [
          {
            "expr": "nr_model_input_tokens_total",
            "legendFormat": "{{model}}",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "${datasource}" }
          }
        ],
        "options": {
          "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "type": "timeseries",
        "pluginId": "timeseries",
        "pluginVersion": "11.5.2"
      }
    }
  },
  "layout": {
    "kind": "GridLayout",
    "spec": {
      "items": [
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 0, "y": 0, "width": 6, "height": 4,
            "element": { "kind": "ElementReference", "name": "requests" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 6, "y": 0, "width": 6, "height": 4,
            "element": { "kind": "ElementReference", "name": "input-tokens" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 12, "y": 0, "width": 6, "height": 4,
            "element": { "kind": "ElementReference", "name": "output-tokens" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 18, "y": 0, "width": 6, "height": 4,
            "element": { "kind": "ElementReference", "name": "cost" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 0, "y": 4, "width": 8, "height": 8,
            "element": { "kind": "ElementReference", "name": "requests-per-model" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 8, "y": 4, "width": 8, "height": 8,
            "element": { "kind": "ElementReference", "name": "cost-per-model" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 16, "y": 4, "width": 8, "height": 8,
            "element": { "kind": "ElementReference", "name": "tokens-per-model" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 0, "y": 12, "width": 12, "height": 8,
            "element": { "kind": "ElementReference", "name": "request-rate" }
          }
        },
        {
          "kind": "GridLayoutItem",
          "spec": {
            "x": 12, "y": 12, "width": 12, "height": 8,
            "element": { "kind": "ElementReference", "name": "input-timeseries" }
          }
        }
      ]
    }
  },
  "links": [],
  "liveNow": false,
  "preferences": {
    "layout": {
      "kind": "GridLayout",
      "spec": { "items": [] }
    }
  },
  "preload": false,
  "tags": ["9router", "cost", "usage"],
  "timeSettings": {
    "autoRefresh": "30s",
    "autoRefreshIntervals": ["5s","10s","30s","1m","5m","15m","30m","1h","2h","1d"],
    "fiscalYearStartMonth": 0,
    "from": "now-6h",
    "hideTimepicker": false,
    "timezone": "browser",
    "to": "now"
  },
  "title": "9Router Usage Analytics",
  "variables": [
    {
      "name": "datasource",
      "type": "datasource",
      "query": "prometheus",
      "hide": 0,
      "label": "Data Source"
    }
  ]
}
